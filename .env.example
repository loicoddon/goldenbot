# ============================================================
# GOLDENBOT — Environment variables
# Copy this file to .env and fill in the values.
# ============================================================

# ---------- Database (Postgres) ----------
POSTGRES_USER=goldenbot
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=goldenbot
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://goldenbot:changeme_local_only@db:5432/goldenbot

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---------- Market data ----------
# Feed selection: "auto" (OANDA primary + TwelveData fallback if both configured)
# "oanda" forces OANDA primary, "twelvedata" forces TwelveData primary
FEED_PROVIDER=auto

# TwelveData — https://twelvedata.com/account/api-keys
TWELVEDATA_API_KEY=
TWELVEDATA_SYMBOL=XAU/USD
TWELVEDATA_POLL_INTERVAL=2

# OANDA v20 — https://www.oanda.com/account/login (create a demo account)
# Get API token: https://www.oanda.com/demo-account/tpa/personal_token
# Account ID format: 101-004-XXXXXXX-001
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice

# Correlated markets (DXY/TNX/WTI/SPX). Free tier TwelveData ne les couvre PAS — laisse à false.
CORRELATED_FEED_ENABLED=false

# ---------- News (Finnhub) — Phase 2 ----------
# https://finnhub.io/dashboard
FINNHUB_API_KEY=
NEWS_CALENDAR_POLL_INTERVAL=300
NEWS_HEADLINES_POLL_INTERVAL=120
# Block trades around high-impact events (minutes)
NEWS_BLOCK_BEFORE_MIN=15
NEWS_BLOCK_AFTER_MIN=15

# ---------- Discord ----------
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# ---------- AI provider ----------
# Backend selection: "claude" | "ollama" | "stub"
AI_PROVIDER=ollama
# Claude (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
# Local Ollama (Mac mini M4)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:14b

# ---------- Trading defaults ----------
INITIAL_CAPITAL=1000
RISK_PER_TRADE_PCT=1.0
DAILY_LOSS_LIMIT_PCT=5.0
MAX_TRADES_PER_DAY=10
DEFAULT_TIMEFRAME=1m
# Broker leverage applied to every position (x500 default = retail forex/CFD typical)
LEVERAGE=500

# ---------- Optimizer — Phase 2 ----------
OPTIMIZER_ENABLED=true
OPTIMIZER_WINDOW_TRADES=20
OPTIMIZER_RUN_EVERY_TRADES=10

# ---------- Backend / Frontend ----------
BACKEND_PORT=8001
FRONTEND_PORT=3010
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=ws://localhost:8001/ws

# ---------- Logging ----------
LOG_LEVEL=INFO

# ---------- Dev mode ----------
# Set to "1" to enable uvicorn --reload (file watcher, hot-reload).
# Leave empty in production: --reload can leave zombie asyncio tasks
# polling external APIs after each code change, which has burned the
# TwelveData free-tier quota in the past.
UVICORN_RELOAD=
